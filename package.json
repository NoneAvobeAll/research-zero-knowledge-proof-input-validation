{
  "name": "pve-zkp",
  "version": "1.0.0",
  "description": "Proof-of-Validated-Execution: ZKP-based input validation for browser forms",
  "scripts": {
    "build:all":    "bash scripts/build_circuits.sh",
    "validate:test":"node prover/generate_proof.js threshold_check prover/inputs/threshold_input.json",
    "verify:test":  "node verifier/verify_proof.js threshold_check outputs/threshold_check/proof.json outputs/threshold_check/public.json",
    "start:validator": "node prover/validator.js",
    "start:receiver":  "node verifier/receiving_system.js"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "express":   "^4.18.2",
    "snarkjs":   "^0.7.3"
  }
}
